# Relevant reverse-proxy routes for the VPS. Merge these directives into the
# real Caddyfile; TLS, security headers and staging authentication stay in the
# VPS configuration.

(proxy_to) {
	reverse_proxy {args[0]} {
		# Replace client-provided forwarding headers with Caddy's direct peer.
		header_up X-Forwarded-For {remote_host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up Host {host}
	}
}

lescocottesdediane.fr {
	# The shop forwards /api requests to NestJS. Its container address must also
	# be covered by the API TRUSTED_PROXIES allowlist.
	import proxy_to prod-shop:3001
}

app.lescocottesdediane.fr {
	handle /uploads/* {
		import proxy_to prod-api:4000
	}

	handle /api/auth* {
		import proxy_to prod-web:3000
	}

	handle /api/admin/* {
		import proxy_to prod-web:3000
	}

	handle /api/* {
		import proxy_to prod-api:4000
	}

	handle {
		import proxy_to prod-web:3000
	}
}

api.lescocottesdediane.fr {
	import proxy_to prod-api:4000
}

dev.lescocottesdediane.fr {
	import proxy_to staging-shop:3001
}

dev.app.lescocottesdediane.fr {
	handle /uploads/* {
		import proxy_to staging-api:4000
	}

	handle /api/auth* {
		import proxy_to staging-web:3000
	}

	handle /api/admin/* {
		import proxy_to staging-web:3000
	}

	handle /api/* {
		import proxy_to staging-api:4000
	}

	handle {
		import proxy_to staging-web:3000
	}
}

dev.api.lescocottesdediane.fr {
	import proxy_to staging-api:4000
}
